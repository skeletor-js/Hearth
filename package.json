{
  "name": "hearth",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A self-evolving macOS desktop client for coding agents (Claude Code, Codex) over ACP.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "test": "bun test",
    "dist": "electron-vite build && electron-builder --mac",
    "publish:update": "node scripts/publish-update.mjs",
    "payload:build": "node scripts/build-workspace-payload.mjs",
    "release": "bun run dist && bun run publish:update && bun run payload:build",
    "create-app": "node scripts/create-micro-app.mjs",
    "view": "node scripts/view-app.mjs",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "ai.hearth.app",
    "productName": "Hearth",
    "asar": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "afterSign": "build/notarize.cjs",
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://pub-aacb176d4db84288936664754f7f6c5b.r2.dev/",
        "channel": "latest"
      }
    ]
  },
  "dependencies": {
    "@agentclientprotocol/codex-acp": "^0.0.44",
    "@agentclientprotocol/sdk": "^0.17.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@phosphor-icons/web": "^2.1.1",
    "@tailwindcss/vite": "^4.1.0",
    "@tanstack/router-plugin": "^1.168.0",
    "@uiw/react-codemirror": "^4.25.10",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@zed-industries/claude-agent-acp": "^0.23.1",
    "dompurify": "^3.4.7",
    "dugite": "^3.2.2",
    "electron-updater": "^6.8.3",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.4",
    "node-pty": "^1.1.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1060.0",
    "@electron/notarize": "^2.5.0",
    "@electron/rebuild": "^4.0.4",
    "@tanstack/react-router": "^1.168.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "zustand": "^5.0.0"
  }
}
