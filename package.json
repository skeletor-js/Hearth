{
  "name": "hearth",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A self-evolving macOS desktop client for coding agents (Claude Code, Codex) over ACP.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
